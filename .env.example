# Required: Apify API token for Alibaba scraping
# Get your token at: https://console.apify.com/account/integrations
APIFY_TOKEN=your_apify_token

# Optional: Local Ollama server configuration
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama2

# Optional: Exchange rate API for live currency conversion
# https://www.exchangerate-api.com/ (free tier works)
EXCHANGERATE_API_KEY=
